<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist additions for Pixels to Macros.

  After running `flutter create . --org com.pixelstomacros --platforms ios`,
  merge these keys into the generated ios/Runner/Info.plist, or replace
  the generated file entirely with a copy that includes them.
-->
<plist version="1.0">
<dict>
  <!-- Camera (required for ARKit) -->
  <key>NSCameraUsageDescription</key>
  <string>Pixels to Macros uses the camera to scan your plate and estimate food calories.</string>

  <!-- Microphone (required by speech_to_text for voice logging) -->
  <key>NSMicrophoneUsageDescription</key>
  <string>Pixels to Macros uses the microphone to listen when you log food by voice.</string>

  <!-- Speech recognition (required by speech_to_text) -->
  <key>NSSpeechRecognitionUsageDescription</key>
  <string>Pixels to Macros uses speech recognition to convert your voice into food items.</string>

  <!-- ARKit world tracking -->
  <key>UIRequiredDeviceCapabilities</key>
  <array>
    <string>arkit</string>
    <string>arm64</string>
  </array>

  <!-- Keep AR session alive briefly when switching views -->
  <key>UIBackgroundModes</key>
  <array>
    <string>processing</string>
  </array>

  <!-- Minimum deployment target (set in Xcode too) -->
  <key>MinimumOSVersion</key>
  <string>17.0</string>

  <!-- Allow HTTPS requests to OpenFoodFacts for barcode nutrition lookup.
       iOS enforces App Transport Security (ATS); this exception permits
       only the specific domain needed and keeps all other domains secure. -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSExceptionDomains</key>
    <dict>
      <key>world.openfoodfacts.org</key>
      <dict>
        <key>NSExceptionAllowsInsecureHTTPLoads</key>
        <false/>
        <key>NSIncludesSubdomains</key>
        <true/>
      </dict>
    </dict>
  </dict>
</dict>
</plist>
